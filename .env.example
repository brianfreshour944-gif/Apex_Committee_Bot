# Required
APCA_API_KEY_ID=your_key_here
APCA_API_SECRET_KEY=your_secret_here
APCA_API_PAPER=true

# Optional — ML model paths (copy from Grok v8 repo)
MODEL_PATH=/app/grok_gqa_v9_best.pth
SCALER_PATH=/app/feature_scaler.pkl

# Optional — tuning
WEIGHT_TRANSFORMER=0.50
WEIGHT_QUANT=0.30
WEIGHT_MOMENTUM=0.20
MIN_VOTE_SCORE=0.60
MAX_SINGLE_TRADE_USD=5000
STOP_LOSS_PCT=0.04
TAKE_PROFIT_PCT=0.06
MAX_HOLD_HOURS=8
SENTINEL_MAX_ATR_PCT=6.0

# Optional — integrations
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
DATABASE_URL=postgresql://user:pass@host:5432/dbname
BOT_NAME=Apex_Committee_v1
HEARTBEAT_PATH=/tmp/committee_heartbeat.txt
